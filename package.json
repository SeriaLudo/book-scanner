{
  "name": "book-scanner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @book-scanner/client --filter @book-scanner/server dev",
    "dev:client": "pnpm --filter @book-scanner/client dev",
    "dev:server": "pnpm --filter @book-scanner/server dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "preview": "pnpm --filter @book-scanner/client preview",
    "db:generate": "pnpm --filter @book-scanner/server db:generate",
    "db:migrate": "pnpm --filter @book-scanner/server db:migrate",
    "db:studio": "pnpm --filter @book-scanner/server db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.39.1"
  }
}
